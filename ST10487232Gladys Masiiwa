lemmatizer = WordNetLemmatizer()
stop_words = set(stopwords.words('english'))

# Custom medical aid background noise words identified during EDA
domain_noise = {'medical', 'aid', 'insurance', 'company', 'scheme', 'health', 'please', 'would', 'also'}
stop_words.update(domain_noise)

def preprocess_text(text):
    if not isinstance(text, str):
        return ''
    # 1. Lowercase text
    text = text.lower()
    # 2. Strip URLs
    text = re.sub(r'http\S+|www\S+', '', text)
    # 3. Strip punctuation and numbers - retain alpha strings only
    text = re.sub(r'[^a-zA-Z\s]', '', text)
    # 4. Academic Tokenization split
    words = nltk.word_tokenize(text)
    # 5. Filter standard stop words and single characters
    words = [w for w in words if w.isalpha() and w not in stop_words and len(w) > 1]
    # 6. Apply Lemmatization to extract base dictionary words
    words = [lemmatizer.lemmatize(w) for w in words]
    return ' '.join(words)

# Clean dataset
